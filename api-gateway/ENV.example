# Production: đặt NODE_ENV=production và CORS_ORIGIN danh sách origin HTTPS (không dùng *)
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# BFF cache + coalesce (wave 3d)
REDIS_HOST=redis
REDIS_PORT=6379
BFF_CACHE_ENABLED=true
BFF_BOOTSTRAP_CACHE_TTL_SEC=45
BFF_SHELL_CACHE_TTL_SEC=60
BFF_DASHBOARD_CACHE_TTL_SEC=45
BFF_DOCUMENTS_OVERVIEW_CACHE_TTL_SEC=45
BFF_DOWNSTREAM_TIMEOUT_MS=7000
GATEWAY_INTERNAL_TOKEN=
