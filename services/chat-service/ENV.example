# Chat Service Environment Variables
# Copy this file to .env and update the values

# Server
NODE_ENV=development
PORT=3006

# Database (tùy chọn DB riêng cho chat — scale / tách tải)
# MONGODB_URI=mongodb://localhost:27017/chat_db
CHAT_MONGODB_URI=
MONGODB_URI=mongodb+srv://nguyenhuy6012004_db_user:nhathuy0305@cluster0.ccaayy0.mongodb.net/chat_db

# RabbitMQ — consumer tin DM bất đồng bộ (socket-service publish)
RABBITMQ_URL=amqp://voicehub:voicehub-dev-change-me@localhost:5672
FRIEND_DM_USE_QUEUE=true

# Realtime publish tới socket-service
SOCKET_SERVICE_URL=http://socket-service:3017
REALTIME_INTERNAL_TOKEN=

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT (để verify token từ auth-service)
JWT_SECRET=your-secret-key-change-in-production



# External Services
USER_SERVICE_URL=http://user-service:3004
ORGANIZATION_SERVICE_URL=http://organization-service:3013
GATEWAY_INTERNAL_TOKEN=

# Org ACL read-model (wave-2c)
ORG_ACL_LOCAL_FRESH_MS=300000
ORG_ACL_CACHE_TTL_SEC=180
ORG_SERVICE_CIRCUIT_FAILURES=3
ORG_SERVICE_CIRCUIT_OPEN_MS=30000
ORG_ACCESSIBLE_CHANNELS_TIMEOUT_MS=12000
ORG_ACL_CONSUMER_ENABLED=false
ORG_EVENT_IDEMPOTENCY_TTL_SEC=86400

# Wave 3B — Meilisearch org message search (browser vẫn gọi GET /api/messages/search qua gateway)
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=voicehub-meili-dev-change-me
MEILI_ORG_MESSAGES_INDEX=org_messages
MESSAGE_SEARCH_ENGINE=meilisearch
MESSAGE_SEARCH_INDEXER_ENABLED=true
MESSAGE_SEARCH_PUBLISH_ENABLED=true
MESSAGE_SEARCH_INLINE_SYNC=false
MESSAGE_SEARCH_BACKFILL_BATCH=200
