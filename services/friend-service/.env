# Friend Service Environment Variables
# Copy this file to .env and update the values

# Server
NODE_ENV=development
PORT=3014

# Database
MONGODB_URI=mongodb+srv://nguyenhuy6012004_db_user:nhathuy0305@cluster0.ccaayy0.mongodb.net/friend_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# External Services
USER_SERVICE_URL=http://user-service:3004
# Tra cứu SĐT nội bộ — trùng user-service + root .env (Compose inject ${USER_SERVICE_INTERNAL_TOKEN})
USER_SERVICE_INTERNAL_TOKEN=dev-user-internal-presence-token-change-me
WEBHOOK_SERVICE_URL=http://webhook-service:3016
WEBHOOK_SECRET=your-webhook-secret-key-change-this-in-production

# Chat service — xóa tin nhắn DM khi hủy kết bạn (cùng giá trị CHAT_INTERNAL_TOKEN với chat-service)
CHAT_SERVICE_URL=http://chat-service:3006
CHAT_INTERNAL_TOKEN=dev-shared-chat-internal-token-change-me

# Hủy kết bạn: giữ DM; xóa vĩnh viễn sau 12h nếu không kết bạn lại (job purge trong friend-service)
FRIEND_UNFRIEND_GRACE_HOURS=12
FRIEND_UNFRIEND_PURGE_POLL_MS=300000

GATEWAY_INTERNAL_TOKEN=dev-gateway-internal-token-change-me

# Realtime (socket-service) — trùng chat-service / docker-compose REALTIME_INTERNAL_TOKEN
SOCKET_SERVICE_URL=http://socket-service:3017
REALTIME_INTERNAL_TOKEN=dev-shared-realtime-token-change-me

# # Kafka
# KAFKA_ENABLED=true
# KAFKA_BROKERS=kafka:9092
# KAFKA_CLIENT_ID=friend-service
# KAFKA_GROUP_ID=friend-domain-consumer-group
# KAFKA_TOPIC_DOMAIN_EVENT=domain.event.v1
# KAFKA_TOPIC_DEAD_LETTER=dead.letter.v1