# Voice Service Environment Variables
# Copy this file to .env and update the values

# Server
NODE_ENV=development
PORT=3005
JWT_SECRET=your-secret-key-change-in-production

# Database
MONGODB_URI=mongodb+srv://nguyenhuy6012004_db_user:nhathuy0305@cluster0.ccaayy0.mongodb.net/voice_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# External Services
USER_SERVICE_URL=http://user-service:3004
ORGANIZATION_SERVICE_URL=http://organization-service:3013

# Cùng api-gateway / organization-service (gatewayTrust — /api/meetings)
GATEWAY_INTERNAL_TOKEN=dev-gateway-internal-token-change-me

# Friend call 1-1: ring/accept/reject → socket-service (trùng chat-service / socket-service)
SOCKET_SERVICE_URL=http://socket-service:3017
REALTIME_INTERNAL_TOKEN=dev-shared-realtime-token-change-me
FRIEND_SERVICE_URL=http://friend-service:3014

# Voice Signaling
VOICE_SIGNAL_PATH=/voice-socket
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,https://voicehub.local

# Mediasoup / WebRTC
MEDIASOUP_LISTEN_IP=0.0.0.0
# Docker dev: IP WiFi LAN — chạy: powershell -File devops\scripts\sync-lan-dev-ip.ps1
# Không dùng 127.0.0.1 (Docker Desktop UDP loopback fail). Có thể nhiều IP: 172.16.x,192.168.x
MEDIASOUP_ANNOUNCED_IP=172.22.16.1,192.168.56.1,192.168.1.3
# Windows + Docker: ưu tiên ICE TCP (UDP range đôi khi vẫn lỗi qua NAT Docker).
MEDIASOUP_PREFER_TCP=true
MEDIASOUP_LOG_LEVEL=warn
MEDIASOUP_INITIAL_OUTGOING_BITRATE=1000000
RTC_MIN_PORT=40000
RTC_MAX_PORT=40100

