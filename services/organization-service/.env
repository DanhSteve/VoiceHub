# Organization Service Environment Variables
# Copy this file to .env and update the values

# Server
NODE_ENV=development
PORT=3013

# Database
MONGODB_URI=mongodb+srv://nguyenhuy6012004_db_user:nhathuy0305@cluster0.ccaayy0.mongodb.net/organization_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# External Services
USER_SERVICE_URL=http://user-service:3004
NOTIFICATION_SERVICE_URL=http://notification-service:3003
WEBHOOK_SERVICE_URL=http://webhook-service:3016
WEBHOOK_SECRET=your-webhook-secret-key-change-this-in-production

# Đồng bộ RBAC với role-permission-service (cùng token với api-gateway)
ROLE_PERMISSION_SERVICE_URL=http://role-permission-service:3015
GATEWAY_INTERNAL_TOKEN=dev-gateway-internal-token-change-me

# Xóa tổ chức — gọi nội bộ các service (cùng token chat với chat-service)
CHAT_SERVICE_URL=http://chat-service:3006
CHAT_INTERNAL_TOKEN=dev-shared-chat-internal-token-change-me
TASK_SERVICE_URL=http://task-service:3009
DOCUMENT_SERVICE_URL=http://document-service:3010
VOICE_SERVICE_URL=http://voice-service:3005
AI_TASK_SERVICE_URL=http://ai-task-service:3020

# Invite Link
INVITE_LINK_SECRET=change-this-in-production
INVITE_LINK_EXPIRES_IN=7d
# Fallback link mời/join khi không có Origin (LAN HTTPS)
FRONTEND_URL=https://voicehub.local

# Org read cache: ACL per user, structure summary per org
ORG_ACL_CACHE_TTL_SEC=180
ORG_STRUCTURE_CACHE_TTL_SEC=600

# Org events — bật khi RabbitMQ sẵn sàng
ORG_ACL_EVENTS_ENABLED=false
ORG_ACL_EVENT_PUBLISH=false
RABBITMQ_URL=amqp://voicehub:voicehub-dev-change-me@localhost:5672
RABBITMQ_EXCHANGE=voicehub.topic