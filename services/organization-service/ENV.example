# Organization Service Environment Variables
# Copy this file to .env and update the values

# Server
NODE_ENV=development
PORT=3013

# Database
MONGODB_URI=mongodb+srv://nguyenhuy6012004_db_user:nhathuy0305@cluster0.ccaayy0.mongodb.net/organization_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
# Org read cache (wave-2b): ACL per user, structure summary per org
ORG_ACL_CACHE_TTL_SEC=180
ORG_STRUCTURE_CACHE_TTL_SEC=600

# Org events (wave-3a) — bật khi RabbitMQ sẵn sàng
ORG_ACL_EVENTS_ENABLED=false
ORG_ACL_EVENT_PUBLISH=false
RABBITMQ_URL=amqp://voicehub:voicehub-dev-change-me@localhost:5672
RABBITMQ_EXCHANGE=voicehub.topic

# External Services
USER_SERVICE_URL=http://user-service:3004
WEBHOOK_SERVICE_URL=http://webhook-service:3016
WEBHOOK_SECRET=your-webhook-secret-key-change-this-in-production

# Invite Link
INVITE_LINK_SECRET=change-this-in-production
INVITE_LINK_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173

