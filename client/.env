# API Gateway – khớp với service api-gateway trong docker-compose
# Dev HTTPS qua Nginx: dùng relative path để tránh lệ thuộc host/IP cụ thể.
VITE_API_URL=/api

# Tạm tắt auto logout khi 401 (debug). Nhớ đặt false hoặc xóa dòng trước production.
VITE_DISABLE_AUTO_LOGOUT=true

# Socket realtime:
# Ép đi qua API Gateway trong dev.
VITE_SOCKET_USE_GATEWAY=true
# Để trống: client tự lấy host từ URL đang mở (vd. 172.16.1.29) + port gateway bên dưới.
VITE_SOCKET_URL=
VITE_GATEWAY_PORT=3000
# Nếu cần fallback proxy /socket.io, chỉ cần sửa target bên dưới.
VITE_SOCKET_PROXY_TARGET=http://127.0.0.1:3000
VITE_VOICE_SIGNAL_PATH=/voice-socket

# FE host/port có thể đổi linh hoạt qua env
VITE_HOST=0.0.0.0
VITE_PORT=5173
# Dev: Vite cho phép mọi host (vite.config.js). Dòng dưới chỉ khi VITE_ALLOWED_HOSTS_STRICT=true.
# IP đổi theo WiFi: chạy devops/scripts/sync-lan-dev-ip.ps1 (cập nhật MEDIASOUP + gợi ý hosts).
VITE_ALLOWED_HOSTS=voicehub.local,voicehub_vite,localhost,127.0.0.1,172.22.16.1,192.168.56.1,192.168.1.3

# HMR qua Nginx TLS :443 — client LAN mở https://voicehub.local (xem docs/lan-https-voicehub-local.md)
VITE_HMR_HOST=voicehub.local
VITE_HMR_PROTOCOL=wss
VITE_HMR_CLIENT_PORT=443

VITE_APP_NAME=Voice Chat App
VITE_APP_VERSION=1.0.0
